# Server
PORT=8080
NODE_ENV=development

# MongoDB Atlas (free M0 cluster)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/raterace?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_string

# Admin panel password — set a strong secret
ADMIN_SECRET=change_me_to_a_strong_admin_password

# LinkedIn OAuth — from linkedin.com/developers
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# LLM provider — 'gemini' or 'groq' (default: gemini)
LLM_PROVIDER=gemini
# Model override — leave blank to use provider default
# Gemini default: gemini-3.1-flash-lite-preview
# Groq default:   llama-3.3-70b-versatile
LLM_MODEL=

# Google Gemini (free tier: 15 RPM, 1B tokens/month — no card required)
# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (free tier — generous limits, sign up at console.groq.com)
# Required when LLM_PROVIDER=groq
# Also required when LLM_PROVIDER=gemini — used as automatic fallback if Gemini hits rate limits or quota
GROQ_API_KEY=your_groq_api_key_here

# Cloudinary (free tier: 25 GB)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Brandfetch logo API — free client ID from developers.brandfetch.com
BRANDFETCH_API_KEY=your_brandfetch_client_id

# CORS — set to your frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# Puppeteer template base URL — must match PORT above
BASE_URL=http://127.0.0.1:8080
