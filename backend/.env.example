# Server
PORT=3000
NODE_ENV=development

# MongoDB Atlas (free M0 cluster)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/raterace?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_string

# Admin panel password — set a strong secret
ADMIN_SECRET=change_me_to_a_strong_admin_password

# LinkedIn OAuth — from linkedin.com/developers
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# Google Gemini (free tier: 15 RPM, 1B tokens/month — no card required)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary (free tier: 25 GB)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — set to your frontend origin
FRONTEND_ORIGIN=http://localhost:8000

# Puppeteer template base URL — must match PORT above
BASE_URL=http://127.0.0.1:3000
